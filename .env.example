# Core API Configuration
OPENAI_API_KEY=your-openai-or-azure-key
OPENAI_API_BASE=https://models.inference.ai.azure.com
APIFY_API_TOKEN=your-apify-token

# Zynd AI On-Chain Payments Configuration
ZYND_REGISTRY_URL=https://zns01.zynd.ai
ZYND_WALLET_ADDRESS=your-base-usdc-wallet-address

# Discord Integration (Webhook URL)
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# Telegram Integration (Bot Token & User Chat ID)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Notion Integration (Create Token at developers.notion.com)
NOTION_INTEGRATION_TOKEN=your-notion-integration-token
NOTION_PARENT_PAGE_ID=your-notion-parent-page-id

# GitHub Access Token (Avoid API rate limits)
GITHUB_TOKEN=your-github-token

# Superplane Canvas Integration
SUPERPLANE_WEBHOOK_URL=your-superplane-webhook-url
ORCHESTRATOR_PORT=8000

# Ngrok Tunnels (Required for Zynd Webhook Delivery during development)
NGROK_AUTH_TOKEN=your-ngrok-token
